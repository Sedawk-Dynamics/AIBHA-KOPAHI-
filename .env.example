# ──────────────────────────────────────────────────────────────────────────────
# Repo-level env file consumed by `docker compose up`.
# Copy to `.env` (gitignored) and fill in.
# ──────────────────────────────────────────────────────────────────────────────

# Postgres — REQUIRED
POSTGRES_PASSWORD=

# Auth — REQUIRED. Generate: openssl rand -hex 48
JWT_SECRET=
JWT_EXPIRES_IN=30d

# Inter-service URLs
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional — outbound email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional — image hosting
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional — payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
