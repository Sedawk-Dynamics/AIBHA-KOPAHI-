# ─────────────────────────────────────────────────────────────────────────────
# Repo-level env consumed by `docker compose up`.
#
# In Dokploy: paste these into the Project's Environment tab (UI). Marked
# REQUIRED ones must be set or compose will refuse to boot.
# ─────────────────────────────────────────────────────────────────────────────

# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Postgres
POSTGRES_USER=kopahi
POSTGRES_DB=kopahi
POSTGRES_PASSWORD=                      # REQUIRED — strong random

# Backend
JWT_SECRET=                             # REQUIRED — `openssl rand -hex 48`
JWT_EXPIRES_IN=30d
LOG_LEVEL=info

# Public hostnames — used both by Traefik (in Dokploy Domains UI) and by the
# apps' build-time / run-time configs. No trailing slash. Use https:// in prod.
FRONTEND_HOST=kopahi.example.com
ADMIN_HOST=admin.kopahi.example.com
API_HOST=api.kopahi.example.com

# Inter-service URLs (must match the hostnames above)
FRONTEND_URL=https://kopahi.example.com
ADMIN_URL=https://admin.kopahi.example.com

# Browser-facing URLs — baked into the Next.js + Vite bundles at BUILD time
NEXT_PUBLIC_API_URL=https://api.kopahi.example.com
NEXT_PUBLIC_ADMIN_URL=https://admin.kopahi.example.com


# ─── OPTIONAL ────────────────────────────────────────────────────────────────

# SMTP — without these, email-verify / password-reset / contact-lead emails are
# stored but skipped (logged as `email_skipped`).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Cloudinary — without these, product image uploads fall back to local /uploads
# (which won't persist across container restarts unless you mount a volume).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay — without these, the payment endpoints return 503.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
