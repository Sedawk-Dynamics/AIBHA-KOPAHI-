# ─────────────────────────────────────────────────────────────────────────────
# Repo-level env consumed by `docker compose up`.
#
# In Dokploy: paste these into the COMPOSE project's Environment tab.
# DATABASE_URL comes from the separate Dokploy "Database" service — open that
# service in Dokploy and copy its internal connection URL.
# ─────────────────────────────────────────────────────────────────────────────

# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Database — copy this from Dokploy → db service → Connection URL
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
# HOST is the internal hostname Dokploy gives you (e.g. `db` or
# `aibha-db-abc123`). Don't use the public port — both apps live on the
# same dokploy-network.
DATABASE_URL=postgresql://kopahi:kopahi@db:5432/kopahi?schema=public

# Legacy Express backend JWT (kopahi-backend/src/middleware/authMiddleware.ts).
# Generate: `openssl rand -hex 48`
JWT_SECRET=
JWT_EXPIRES_IN=30d
LOG_LEVEL=info

# v9-REST auth (Next.js Route Handlers in kopahi-frontend/app/api/auth/*).
# Generate each fresh, distinct: `openssl rand -base64 64`
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
BCRYPT_COST=12

# At-rest encryption key for vendor KYC (bank account etc — Phase 2).
# Generate: `openssl rand -hex 32`
# DO NOT change after data is encrypted — rotation requires re-encrypting.
ENCRYPTION_KEY=

# Demo flag — MUST be "false" in production for both server + browser builds.
ENABLE_DEMO=false
NEXT_PUBLIC_ENABLE_DEMO=false
NEXT_PUBLIC_DEMO_PASSWORD=

# Public hostnames (no scheme, no trailing slash)
FRONTEND_HOST=kopahi.com
ADMIN_HOST=admin.kopahi.com
API_HOST=api.kopahi.com
\
# Inter-service URLs (with https://). FRONTEND_URL is also used as the
# `APP_URL` injected into the frontend container — verification + password
# reset email links are built off it.
FRONTEND_URL=https://kopahi.com
ADMIN_URL=https://admin.kopahi.com

# Browser-facing URLs — baked into the Next.js + Vite bundles at BUILD time.
# Changing these requires Dokploy → Redeploy (not Restart).
NEXT_PUBLIC_API_URL=https://api.kopahi.com
NEXT_PUBLIC_ADMIN_URL=https://admin.kopahi.com

# Resend transactional email.
# Get an API key at https://resend.com/api-keys
# Until kopahi.com is verified at https://resend.com/domains, EMAIL_FROM
# must stay on Resend's test domain AND the only allowed recipient is the
# Resend signup email.
RESEND_API_KEY=
EMAIL_FROM=Kopahi <onboarding@resend.dev>
EMAIL_REPLY_TO=info@kopahi.com



# ─── OPTIONAL ────────────────────────────────────────────────────────────────

# SMTP — legacy Express transactional email. Unused once v9-REST + Resend
# fully replace the Express auth paths. Leave empty.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Cloudinary — without these, product image uploads fall back to local /uploads
# (which won't persist across container restarts unless you mount a volume).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay — without these, the payment endpoints return 503.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
