{
  "name": "kopahi-backend",
  "version": "1.0.0",
  "description": "Backend for Kopahi B2B2C agri-marketplace",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --watch src --watch prisma --ext ts,json --exec ts-node src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "seed": "ts-node prisma/seed.ts",
    "smoke": "ts-node --project ../scripts/tsconfig.json --transpile-only ../scripts/smoke-test.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "kopahi",
    "backend",
    "nodejs",
    "express",
    "typescript",
    "prisma",
    "postgres"
  ],
  "author": "Shivendra",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "9.0.3",
    "multer": "2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "8.0.5",
    "prisma": "6.19.3",
    "rate-limit-redis": "^4.3.1",
    "razorpay": "^2.9.6",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.40",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "embedded-postgres": "^18.3.0-beta.17",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
