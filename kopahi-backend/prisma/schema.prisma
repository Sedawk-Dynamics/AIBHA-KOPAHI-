// Kopahi data model — see ../POSTGRES_MIGRATION.md
// IDs use cuid so the API contract can keep returning string identifiers
// (the db/ layer also tacks _id = id onto every result for legacy callers).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  vendor
  admin
}

enum PaymentStatus {
  Pending
  Paid
  Failed
}

enum OrderStatus {
  Placed
  Processing
  Packed
  Shipped
  Delivered
  Cancelled
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  password     String
  phone        String  @default("")
  role         Role    @default(user)
  businessName String  @default("")
  gstNumber    String  @default("")

  emailVerified            Boolean   @default(false)
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  passwordResetToken       String?
  passwordResetExpires     DateTime?

  // Account lockout — see authController.loginUser. 5 consecutive failed
  // password attempts locks the account for 15 minutes; auto-unlocks on
  // expiry. Demo seed accounts bypass this when ENABLE_DEMO=true.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Sign-in tracking (security signal + audit visibility).
  lastSignInAt DateTime?
  lastSignInIp String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordersPlaced     Order[]    @relation("OrderUser")
  productsOwned    Product[]  @relation("ProductVendor")
  productsApproved Product[]  @relation("ProductApprover")
  reviews          Review[]
  wishlist         Wishlist[]
  cart             CartItem[]
  auditLogs        AuditLog[] @relation("AuditActor")

  @@index([role])
  @@index([emailVerificationToken])
  @@index([passwordResetToken])
}

model Product {
  id               String  @id @default(cuid())
  name             String
  slug             String  @unique
  description      String
  shortDescription String  @default("")
  brand            String  @default("Kopahi")
  category         String
  vendorId         String?
  vendor           User?   @relation("ProductVendor", fields: [vendorId], references: [id], onDelete: SetNull)
  price            Decimal @db.Decimal(10, 2)
  originalPrice    Decimal @default(0) @db.Decimal(10, 2)
  discount         Int     @default(0)
  stock            Int     @default(0)
  unit             String  @default("kg")
  images           String[]
  tags             String[]
  featured         Boolean @default(false)
  isActive         Boolean @default(true)
  rating           Decimal @default(0) @db.Decimal(3, 2)
  numReviews       Int     @default(0)
  seoTitle         String?
  seoDescription   String?

  // Approval workflow: new products start PENDING. Admin sets APPROVED or
  // REJECTED. Customer-facing listings only show APPROVED + isActive.
  approvalStatus  ApprovalStatus @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?
  approver        User?          @relation("ProductApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews    Review[]
  orderItems OrderItem[]
  wishedBy   Wishlist[]
  inCarts    CartItem[]

  @@index([vendorId])
  @@index([category])
  @@index([featured, isActive])
  @@index([approvalStatus])
}

model Review {
  id        String  @id @default(cuid())
  productId String
  userId    String?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String?
  rating    Int     @default(5)
  comment   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model Order {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation("OrderUser", fields: [userId], references: [id])
  shippingAddress Json
  paymentMethod   String        @default("COD")
  paymentStatus   PaymentStatus @default(Pending)
  orderStatus     OrderStatus   @default(Placed)
  itemsPrice      Decimal       @default(0) @db.Decimal(10, 2)
  shippingPrice   Decimal       @default(0) @db.Decimal(10, 2)
  taxPrice        Decimal       @default(0) @db.Decimal(10, 2)
  totalPrice      Decimal       @db.Decimal(10, 2)
  couponCode      String        @default("")
  couponDiscount  Decimal       @default(0) @db.Decimal(10, 2)
  paidAt          DateTime?
  deliveredAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@index([userId, createdAt])
  @@index([paymentStatus])
  @@index([orderStatus])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String?
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String
  image     String   @default("")
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int

  @@index([orderId])
  @@index([productId])
}

model Wishlist {
  userId    String
  productId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, productId])
  @@index([userId])
}

model CartItem {
  userId    String
  productId String
  quantity  Int      @default(1)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@id([userId, productId])
  @@index([userId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  image     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id             String   @id @default(cuid())
  name           String?
  email          String?
  phone          String?
  message        String?
  source         String   @default("Website")
  status         String   @default("New")
  emailDelivered Boolean  @default(false)
  emailError     String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([createdAt])
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String    @default("")
  percentDiscount Int
  minSubtotal     Decimal   @default(0) @db.Decimal(10, 2)
  maxDiscount     Decimal   @default(0) @db.Decimal(10, 2)
  usageLimit      Int       @default(0)
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String   @default("")
  content     String
  coverImage  String   @default("")
  author      String   @default("Kopahi Team")
  tags        String[]
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, publishedAt])
}

// Key/value store for admin Settings. The settings page is a multi-tab
// form; we serialize each tab as a JSON blob under a stable key (e.g.
// "general", "shipping", "payments") so the schema doesn't have to know
// every individual field.
model Setting {
  key       String   @id
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail String?
  actorRole  String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  ip         String?
  userAgent  String?
  requestId  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([actorId, createdAt])
}
