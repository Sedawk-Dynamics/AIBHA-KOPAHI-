# ──────────────────────────────────────────────────────────────────────────────
# Kopahi backend — environment template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ──────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Database — PostgreSQL connection URL consumed by Prisma
DATABASE_URL=postgresql://kopahi:kopahi@127.0.0.1:5432/kopahi?schema=public

# Auth
# Generate one: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
# WARNING: if `JWT_SECRET` ends up appearing twice in your `.env`, dotenv
# silently takes the LAST occurrence — a stray copy of this template's
# placeholder will override your real secret and quietly break JWT signing
# without any error. Keep exactly one assignment.
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=30d

# CORS / frontend origin (used in emails too)
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# At-rest encryption key for vendor KYC (bank account, IFSC, UPI).
# Generate one: `openssl rand -hex 32`  (or)  `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# Required when src/utils/crypto.ts is exercised — Phase 2 vendor onboarding.
# DO NOT change after data has been encrypted, or existing rows become
# undecipherable. Rotation requires re-encrypting every affected row.
ENCRYPTION_KEY=

# Demo seed accounts (admin/vendor/customer@kopahi.com) bypass rate-limit
# AND account lockout when set to "true". MUST be "false" in production.
ENABLE_DEMO=false

# SMTP (optional — without these, transactional emails are skipped & logged)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Cloudinary (optional — without these, images fall back to local /uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (optional — payment endpoints return 503 until set)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
