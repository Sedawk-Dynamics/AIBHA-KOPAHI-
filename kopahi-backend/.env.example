# ──────────────────────────────────────────────────────────────────────────────
# Kopahi backend — LOCAL DEV .env
# Never commit. Production secrets live in Dokploy's project env tab.
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Postgres (shared with frontend Prisma)
DATABASE_URL=postgresql://kopahi:kopahi@127.0.0.1:5432/kopahi?schema=public

# Auth — local-dev value. Rotate in prod via Dokploy env tab.
JWT_SECRET=local_dev_a91f4c2b88e07d5e6133fa88c4d26cf84a73ab5c2f41d09b1e76d5c2a08bf932
JWT_EXPIRES_IN=30d
JWT_ACCESS_SECRET=2Pj7qydCZBGCIWsSHetBBKMVYiw/AQ2YJCJ+2sFwXz7XYjo/mbBH8wg0Ymns4W41+221WCvODhDaUwHtST0Nrg
JWT_REFRESH_SECRET=W9Epp+QPiafYIdZlMskJSc5c6KDso8sVIS2CeoODsF9Gyp0m3KQytLnGthmEAhShuSe3mr7vuVbB1d8HojgvsA

# CORS / email link base URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# At-rest encryption key for vendor KYC (Phase 2). Local-dev value below;
# generate a fresh one for prod with `openssl rand -hex 32`. DO NOT change
# after data has been encrypted — rotation requires re-encrypting every row.
ENCRYPTION_KEY=f45e3605faa5e4b0b91c39ba0b771fea867c1f7bdb09227e320ecedafef7431f

# Demo seed accounts (admin/vendor/customer@kopahi.com) bypass rate-limit
# AND account lockout when "true". MUST be "false" in production.
ENABLE_DEMO=true

# admin@kopahi.com    / DemoPass!2026   http://localhost:3001/admin
# vendor@kopahi.com   / DemoPass!2026   http://localhost:3001/vendor
# customer@kopahi.com / DemoPass!2026   http://localhost:3000/dashboard

# ─── Optional (graceful degradation when empty) ───────────────────────────────

# SMTP — without these, transactional emails are skipped & logged
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Cloudinary — without these, images fall back to local /uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay — payment endpoints return 503 until these are set
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
